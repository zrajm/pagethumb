{
  "manifest_version": 3,
  "name": "Like Page",
  "version": "1.0",
  "description": "Like a page – saves as a bookmark.",
  "icons": {
    "48": "hilite.svg"
  },
  "permissions": ["bookmarks", "tabs", "activeTab"],
  "background": { "scripts": ["background.js"] },
  "action": {
    "default_icon": {
      "16": "normal.svg",
      "32": "normal.svg"
    },
    "default_title": "Like page"
  }
}
