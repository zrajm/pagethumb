{
  "manifest_version": 3,
  "name": "Like Page",
  "version": "1.0",
  "description": "Like, dislike, or bookmark a page.",
  "icons": {
    "48": "pic/like-hilite.svg"
  },
  "permissions": ["bookmarks", "tabs", "activeTab"],
    "background": {
        "type": "module",
        "scripts": ["background.js"]
    },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "pic/like-normal.svg",
      "32": "pic/like-normal.svg"
    },
    "default_title": "Like/dislike Page"
  }
}
